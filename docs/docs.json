{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Arca",
  "logo": {
    "dark": "/logo-dark.png",
    "light": "/logo-light.png"
  },
  "favicon": "/logo.png",
  "theme": "maple",
  "appearance": {
    "default": "dark"
  },
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1E3A8A"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@arca.com"
      },
      {
        "label": "Example App",
        "href": "https://github.com/Vishal-770/arca/tree/main/demo-app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://arca7.vercel.app/dashboard"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Vishal-770/arca"
    }
  },
  "api": {
    "mdx": {
      "server": "https://api-arca.vercel.app"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "pricing"
            ]
          },
          {
            "group": "React SDK",
            "pages": [
              "sdk/introduction",
              "sdk/setup",
              "sdk/client",
              {
                "group": "Components",
                "pages": [
                  "sdk/components/arca-provider",
                  "sdk/components/arca-pricing-table"
                ]
              },
              "sdk/hooks/use-arca",
              "sdk/hooks/use-arca-perks",
              "sdk/theming",
              "sdk/types",
              "sdk/example-app"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/authentication",
              "api-reference/wallet",
              "api-reference/analytics"
            ]
          },
          {
            "group": "Plans",
            "pages": [
              "api-reference/list-plans",
              "api-reference/get-plan",
              "api-reference/plan-analytics"
            ]
          },
          {
            "group": "Subscribers",
            "pages": [
              "api-reference/subscribers"
            ]
          }
        ]
      }
    ]
  }
}
