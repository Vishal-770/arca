  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts --minify --clean",
    "dev": "tsup src/index.tsx --format cjs,esm --watch --dts",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.1",
    "lucide-react": "^0.446.0",
