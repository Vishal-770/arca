    "web3",
    "subscriptions",
    "react",
    "sdk"
  ],
  "description": "Arca Protocol React SDK for building high-performance subscription interfaces.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vishal-770/arca.git"
  },
